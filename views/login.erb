

<html lang="en">
<head>
    <title>login page</title>
    
    <link rel="stylesheet" href="login.css">

    <meta name="author" content="Ben Whittaker">
    <%= erb :"common/header" %>
</head>



<body>
  <section>
    <div class="centerOfScreen">
        <p>this is where you login</p>
        <form method="post" action="login-attempt">
            <label for="username">Username:</label><br>
            <input type="text" id="username" name="username" placeholder="username" value=<%= @username%>><br>
            <label for="password">Password:</label><br>
            <input type="password" id="password" name="password" placeholder="1234"><br>
            <input type="submit" value="Submit" id="submit">
            <br>
            <strong class="error"><%= @login_error %></strong>
        </form>
        
        <a href="/reset-pass">forgot password</a>
    </div>
  </section>
</body>

<footer>



</footer>
</html>